{
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/start-claude-watch.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/save-wip-snapshot.sh stop"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/save-wip-snapshot.sh precompact"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/save-wip-snapshot.sh sessionend"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(git status)",
      "Bash(git status -*)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git show *)",
      "Bash(git branch *)",
      "Bash(git stash list)",
      "Bash(ls *)",
      "Bash(find *)",
      "Bash(rg *)",
      "Bash(fd *)",
      "Bash(grep *)",

      "Bash(npm run *)",
      "Bash(npm test *)",
      "Bash(npm exec *)",
      "Bash(npx *)",
      "Bash(pnpm *)",
      "Bash(pnpm run *)",
      "Bash(pnpm exec *)",
      "Bash(pnpx *)",
      "Bash(yarn *)",

      "Bash(bun *)",
      "Bash(bunx *)",

      "Bash(bundle exec *)",
      "Bash(bundle exec rspec *)",
      "Bash(bundle exec rake *)",
      "Bash(bundle exec sidekiq*)",
      "Bash(rspec *)",
      "Bash(bin/rails *)",
      "Bash(bin/rails test *)",
      "Bash(bin/rails console)",
      "Bash(bin/rails console -- *)",
      "Bash(bin/rake *)",
      "Bash(rake *)",

      "Bash(next *)",
      "Bash(next dev *)",
      "Bash(next build *)",
      "Bash(next start *)",
      "Bash(next lint *)",

      "Bash(vitest *)",
      "Bash(jest *)",
      "Bash(playwright *)",

      "Bash(pytest *)",
      "Bash(uv run *)",
      "Bash(poetry run *)",

      "Bash(go test *)",
      "Bash(go build *)",
      "Bash(go run *)",
      "Bash(go vet *)",

      "Bash(tofu *)",
      "Bash(tofu fmt*)",
      "Bash(tofu validate*)",
      "Bash(tofu plan*)",
      "Bash(terraform *)",
      "Bash(terraform fmt*)",
      "Bash(terraform validate*)",
      "Bash(terraform plan*)",

      "Bash(docker compose config*)",
      "Bash(docker compose ps*)",
      "Bash(docker compose logs*)",
      "Bash(docker ps*)",
      "Bash(docker logs*)",

      "Bash(shopify theme check*)",
      "Bash(shopify theme list*)",
      "Bash(shopify theme dev*)",

      "Read(.wip/**)",
      "Edit(.wip/**)",
      "Bash(~/.claude/ai-dev-workflow/bin/aidw *)"
    ],
    "ask": [
      "Bash(git commit *)",
      "Bash(git push*)",
      "Bash(git checkout *)",
      "Bash(git switch *)",
      "Bash(git reset *)",
      "Bash(git rebase *)",
      "Bash(npm install *)",
      "Bash(pnpm install *)",
      "Bash(yarn add *)",
      "Bash(bun install*)",
      "Bash(bundle add *)",
      "Bash(bundle install*)",
      "Bash(bin/rails db:migrate*)",
      "Bash(bin/rails db:rollback*)",
      "Bash(bin/rails db:seed*)",
      "Bash(bin/rails db:reset*)",
      "Bash(bin/rails generate *)",
      "Bash(tofu apply*)",
      "Bash(tofu destroy*)",
      "Bash(tofu init*)",
      "Bash(terraform apply*)",
      "Bash(terraform destroy*)",
      "Bash(terraform init*)",
      "Bash(docker compose up*)",
      "Bash(docker compose down*)",
      "Bash(docker compose restart*)",
      "Bash(shopify theme push*)",
      "Bash(shopify app deploy*)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(./secrets/**)",
      "Read(~/.aws/credentials)",
      "Read(~/.ssh/id_*)",
      "Bash(curl *)",
      "Bash(wget *)"
    ]
  }
}
