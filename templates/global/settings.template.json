{
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/start-claude-watch.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/save-wip-snapshot.sh stop"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/save-wip-snapshot.sh precompact"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/save-wip-snapshot.sh sessionend"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(ls *)",
      "Bash(find *)",
      "Bash(rg *)",
      "Bash(fd *)",
      "Bash(npm run lint)",
      "Bash(npm run test *)",
      "Bash(bundle exec rspec *)",
      "Bash(bin/rails test *)",
      "Bash(pytest *)",
      "Read(.wip/**)",
      "Edit(.wip/**)",
      "Bash(~/.claude/ai-dev-workflow/bin/aidw *)"
    ],
    "ask": [
      "Bash(git commit *)",
      "Bash(git checkout *)",
      "Bash(git switch *)",
      "Bash(npm install *)",
      "Bash(yarn add *)",
      "Bash(bundle add *)",
      "Bash(bin/rails db:migrate*)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(~/.aws/credentials)",
      "Bash(curl *)",
      "Bash(wget *)"
    ]
  }
}
